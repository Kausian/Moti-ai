# Moti AI — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets. This template holds placeholders only.

# --- AI provider (added in a later phase; not used in Phase 1) ---
# Server-side only. Google Gemini API key used by Next.js Route Handlers.
# The AI provider is called exclusively from the server; this key must never
# be exposed to the browser (do not prefix with NEXT_PUBLIC_).
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model id used for grounded conversation (example placeholder).
GEMINI_MODEL=gemini-1.5-flash
