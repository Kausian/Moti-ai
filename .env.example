# Moti AI — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or a real API key. This template holds placeholders only.

# --- Gemini AI (Phase 5 — server-side only) ---
# Used by the Next.js Route Handler at /api/chat to generate grounded answers.
# Server-only: it is read with process.env on the server and is NEVER exposed to
# the browser. Do NOT prefix with NEXT_PUBLIC_. The app builds and runs without a
# key; the conversation reports "AI conversation is not configured" until one is set.
GEMINI_API_KEY=your-gemini-api-key-here

# Model id (sample). Read from GEMINI_MODEL; falls back server-side to the
# confirmed default (gemini-3.1-flash-lite) if unset.
GEMINI_MODEL=gemini-3.1-flash-lite
